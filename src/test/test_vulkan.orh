module main

import orhonsdl3
import vulkan
import std::console

pub func run_vulkan_test() void {
    console.println("--- Vulkan Renderer Test ---")

    if(!orhonsdl3.init(orhonsdl3.INIT_VIDEO)) {
        console.println("SDL3 init failed:")
        console.println(orhonsdl3.getError())
        return
    }
    defer { orhonsdl3.quit() }

    console.println("SDL3 init: ok")

    const winResult = orhonsdl3.Window.create("Vulkan Test", 800, 600, orhonsdl3.WINDOW_VULKAN | orhonsdl3.WINDOW_RESIZABLE)
    if(winResult is Error) {
        console.println("Window creation failed:")
        console.println(winResult.Error)
        return
    }
    var win = winResult.value
    defer { win.destroy() }

    console.println("Window created with Vulkan flag")

    const renResult = vulkan.Renderer.create(win.getHandle(), true)
    if(renResult is Error) {
        console.println("Vulkan renderer creation failed:")
        console.println(renResult.Error)
        return
    }
    var ren = renResult.value
    defer { ren.destroy() }

    console.println("Vulkan renderer: ok")
    console.println("Window open — press ESC or close to quit")

    ren.setClearColor(0.1, 0.1, 0.15, 1.0)

    var event = orhonsdl3.Event.create()
    var running: bool = true

    while(running) {
        while(event.poll()) {
            const evType = event.getType()
            if(evType == orhonsdl3.EVENT_QUIT) {
                running = false
            }
            if(evType == orhonsdl3.EVENT_KEY_DOWN) {
                if(event.getScancode() == orhonsdl3.SCANCODE_ESCAPE) {
                    running = false
                }
            }
        }

        if(ren.beginFrame()) {
            ren.endFrame()
        }

        orhonsdl3.delay(16)
    }

    console.println("Test complete.")
}
