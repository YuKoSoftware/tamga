module main

import tamga_sdl3
import tamga_vk3d
import std::console

pub func run_vulkan_test() void {
    console.println("--- Vulkan Renderer Test ---")

    const initResult = tamga_sdl3.initPlatform()
    if(initResult is Error) {
        console.println("SDL3 init failed:")
        console.println(tamga_sdl3.getError())
        return
    }
    defer { tamga_sdl3.quitPlatform() }

    console.println("SDL3 init: ok")

    const winResult = tamga_sdl3.Window.create("Vulkan Test", 800, 600, 8)
    if(winResult is Error) {
        console.println("Window creation failed:")
        console.println(tamga_sdl3.getError())
        return
    }
    var win = winResult.value
    defer { win.destroy() }

    console.println("Window created with Vulkan flag")

    const renResult = tamga_vk3d.Renderer.create(win.getHandle().handle, true)
    if(renResult is Error) {
        console.println("Vulkan renderer creation failed:")
        console.println(renResult.Error)
        return
    }
    var ren = renResult.value
    defer { ren.destroy() }

    console.println("Vulkan renderer: ok")
    console.println("Window open — press ESC or close to quit")

    ren.setClearColor(0.1, 0.1, 0.15, 1.0)

    var running: bool = true

    while(running) {
        const evResult = tamga_sdl3.pollEvent()
        if(evResult is not null) {
            const ev = evResult.value
            if(ev.kind == tamga_sdl3.EventKind.Quit) {
                running = false
            }
            if(ev.kind == tamga_sdl3.EventKind.WindowClose) {
                running = false
            }
            if(ev.kind == tamga_sdl3.EventKind.KeyDown) {
                if(ev.key.scancode == 37) {
                    running = false
                }
            }
        }

        if(ren.beginFrame()) {
            ren.endFrame()
        }

        tamga_sdl3.delayNS(16000000)
    }

    console.println("Test complete.")
}
