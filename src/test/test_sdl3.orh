module main

import tamga_sdl3
import std::console

pub func run_sdl3_test() void {
    console.println("--- SDL3 Bridge Test ---")

    if(!tamga_sdl3.init(tamga_sdl3.INIT_VIDEO)) {
        console.println("SDL3 init failed:")
        console.println(tamga_sdl3.getError())
        return
    }
    defer { tamga_sdl3.quit() }

    console.println("SDL3 init: ok")

    const winResult = tamga_sdl3.Window.create("tamga_sdl3 test", 800, 600, tamga_sdl3.WINDOW_RESIZABLE)
    if(winResult is Error) {
        console.println("Window creation failed:")
        console.println(winResult.Error)
        return
    }
    var win = winResult.value
    defer { win.destroy() }

    const renResult = tamga_sdl3.Renderer.create(win)
    if(renResult is Error) {
        console.println("Renderer creation failed:")
        console.println(renResult.Error)
        return
    }
    var ren = renResult.value
    defer { ren.destroy() }

    console.println("Window open — press ESC or close to quit")

    var event = tamga_sdl3.Event.create()
    var running: bool = true

    while(running) {
        while(event.poll()) {
            const evType = event.getType()
            if(evType == tamga_sdl3.EVENT_QUIT) {
                running = false
            }
            if(evType == tamga_sdl3.EVENT_KEY_DOWN) {
                if(event.getScancode() == tamga_sdl3.SCANCODE_ESCAPE) {
                    running = false
                }
            }
        }

        ren.setDrawColor(25, 25, 40, 255)
        ren.clear()
        ren.present()

        tamga_sdl3.delay(16)
    }

    console.println("Test complete.")
}
