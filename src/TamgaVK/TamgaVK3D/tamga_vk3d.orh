module tamga_vk3d

#version = (0, 2, 0)
#build   = static

// ---- Resource IDs ----
// Lightweight typed indices into the renderer's internal slot maps.
// Created by Renderer methods, passed back to draw/destroy calls.

pub struct MeshId {
    pub id: u32
}

pub struct TextureId {
    pub id: u32
}

pub struct MaterialId {
    pub id: u32
}
